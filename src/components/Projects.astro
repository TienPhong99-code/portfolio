---
---
<section class="section pinned-projects">
  <div class="container">
    <h2 class="fade-up">Featured Work</h2>
    <div class="projects-layout fade-up">
      <!-- Project 1 -->
      <div class="project-card">
        <div class="project-info">
          <h3>E-Commerce Platform</h3>
          <p>High performance storefront built with Next.js and Shopify Headless API.</p>
          <a href="#" class="project-link">View Case Study &rarr;</a>
        </div>
        <div class="project-visual bg-1"></div>
      </div>
      
      <!-- Project 2 -->
      <div class="project-card">
        <div class="project-info">
          <h3>Digital Agency</h3>
          <p>Award-winning marketing site featuring immersive 3D WebGL experiences.</p>
          <a href="#" class="project-link">View Case Study &rarr;</a>
        </div>
        <div class="project-visual bg-2"></div>
      </div>
    </div>
  </div>
</section>

<style>
  .pinned-projects {
    background-color: #111;
  }

  .projects-layout {
    display: flex;
    flex-direction: column;
    gap: 4rem;
    margin-top: 4rem;
  }

  .project-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  @media (max-width: 768px) {
    .project-card {
      grid-template-columns: 1fr;
    }
    .project-card:nth-child(even) .project-visual {
      grid-row: 1;
    }
  }

  .project-info h3 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  .project-info p {
    font-size: 1.2rem;
    color: #a3a3a3;
    margin-bottom: 2rem;
  }

  .project-link {
    color: var(--accent-color);
    text-decoration: none;
    font-size: 1.1rem;
    font-weight: 600;
  }

  .project-visual {
    width: 100%;
    aspect-ratio: 4/3;
    border-radius: 8px;
    background-size: cover;
    background-position: center;
    background-color: #222;
  }

  .bg-1 {
    background: linear-gradient(45deg, #1f2937, #3b82f6);
  }
  
  .bg-2 {
    background: linear-gradient(45deg, #4c1d95, #ec4899);
  }
</style>
