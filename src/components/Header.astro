---
import Button from "./Button.astro";
---

<header class="header">
  <div
    class="wrap-logo max-lg:text-[1.8vw] max-lg:gap-[30vw] fixed inset-0 flex h-screen w-screen flex-col items-center justify-center pointer-events-none"
  >
    <div class="heroT">
      <h2>PHONGHT.DEV</h2>
      <h2>PHONGHT.DEV</h2>
    </div>
  </div>
  <div class="container">
    <div class="h-full justify-between items-center flex">
      <a
        href=""
        target="_blank"
        rel="noopener noreferrer"
        class="logo font-bold"
      >
      </a>
      <div class="flex items-center gap-3">
        <a
          href="/assets/cv-phonght.pdf"
          download
          class="cv-btn"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
            <polyline points="7 10 12 15 17 10"></polyline>
            <line x1="12" y1="15" x2="12" y2="3"></line>
          </svg>
          <span>Tải CV</span>
        </a>
        <Button />
      </div>
    </div>
  </div>
</header>
