---
---
<section class="section skills">
  <div class="container">
    <h2 class="fade-up">Skills & Stack</h2>
    <div class="skills-grid fade-up">
      <div class="skill-category">
        <h3>Core Frontend</h3>
        <ul>
          <li>TypeScript</li>
          <li>React / Next.js</li>
          <li>Astro</li>
          <li>Tailwind CSS</li>
        </ul>
      </div>
      <div class="skill-category">
        <h3>Animation & Interactive</h3>
        <ul>
          <li>GSAP</li>
          <li>Framer Motion</li>
          <li>Three.js</li>
          <li>Lenis Scroll</li>
        </ul>
      </div>
      <div class="skill-category">
        <h3>Backend & DevOps</h3>
        <ul>
          <li>Node.js</li>
          <li>PostgreSQL</li>
          <li>Docker</li>
          <li>AWS / Vercel</li>
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 3rem;
    margin-top: 4rem;
  }

  .skill-category h3 {
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--accent-color);
    display: inline-block;
  }

  .skill-category ul {
    list-style: none;
    padding: 0;
  }

  .skill-category li {
    font-size: 1.2rem;
    color: #a3a3a3;
    margin-bottom: 0.8rem;
    position: relative;
    padding-left: 1.5rem;
  }

  .skill-category li::before {
    content: "▹";
    position: absolute;
    left: 0;
    color: var(--accent-color);
  }
</style>
