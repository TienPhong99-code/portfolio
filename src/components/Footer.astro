---
const navLinks = [
  { label: "Giới thiệu", href: "#about" },
  { label: "Dự án", href: "#projects" },
  { label: "Dịch vụ", href: "#services" },
  { label: "Liên hệ", href: "#connect" },
];

const socials = [
  {
    label: "GitHub",
    href: "https://github.com/",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>`,
  },
  {
    label: "LinkedIn",
    href: "https://linkedin.com/in/",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`,
  },
  {
    label: "Facebook",
    href: "https://facebook.com/",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>`,
  },
];
---

<footer class="footer">
  <div class="container">
    <div class="footer-inner">
      <div class="footer-top">
        <div class="footer-brand">
          <p class="footer-name">PHONGHT.DEV</p>
          <p class="footer-tagline">
            Tôi không chỉ xây dựng website,<br />tôi xây dựng sự tin tưởng và
            cảm xúc của người dùng.
          </p>
        </div>

        <nav class="footer-nav">
          {
            navLinks.map((link) => (
              <a href={link.href} class="footer-nav-link">
                {link.label}
              </a>
            ))
          }
        </nav>

        <div class="footer-social">
          <p class="footer-social-label">Kết nối</p>
          <div class="footer-social-links">
            {
              socials.map((s) => (
                <a
                  href={s.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="footer-social-link"
                  aria-label={s.label}
                  set:html={s.icon}
                />
              ))
            }
          </div>
        </div>
      </div>

      <div class="footer-divider"></div>

      <div class="footer-bottom">
        <p class="footer-copy">
          © {new Date().getFullYear()} Hồ Tiên Phong. All rights reserved.
        </p>
        <a href="#" class="footer-back-top" id="backToTop" aria-label="Về đầu trang">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="m18 15-6-6-6 6"></path>
          </svg>
          <span>Về đầu trang</span>
        </a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    position: relative;
    padding: 60px 0 32px;
    margin-top: 20px;
  }

  .footer::before {
    content: "";
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: calc(100% - 30px);
    max-width: 1400px;
    height: 1px;
    background: linear-gradient(
      to right,
      transparent,
      hsla(0, 0%, 100%, 0.1) 20%,
      hsla(0, 0%, 100%, 0.1) 80%,
      transparent
    );
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  .footer-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 48px;
    flex-wrap: wrap;
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-width: 280px;
  }

  .footer-name {
    font-size: 1.1rem;
    font-weight: 700;
    color: #fff;
    margin: 0;
    background: linear-gradient(0deg, #bad1f1 30%, #9dc3f7 100%);
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    letter-spacing: 0.04em;
  }

  .footer-tagline {
    font-size: 0.82rem;
    color: rgba(255, 255, 255, 0.4);
    line-height: 1.65;
    margin: 0;
  }

  .footer-nav {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .footer-nav-link {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.45);
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-nav-link:hover {
    color: #fff;
  }

  .footer-social {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .footer-social-label {
    font-size: 0.7rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.3);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 0;
  }

  .footer-social-links {
    display: flex;
    gap: 12px;
  }

  .footer-social-link {
    width: 38px;
    height: 38px;
    border-radius: 10px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.03);
    color: rgba(255, 255, 255, 0.45);
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    transition:
      color 0.2s,
      border-color 0.2s,
      background 0.2s;
  }

  .footer-social-link:hover {
    color: #9dc3f7;
    border-color: rgba(157, 195, 247, 0.3);
    background: rgba(157, 195, 247, 0.06);
  }

  .footer-divider {
    width: 100%;
    height: 1px;
    background: linear-gradient(
      to right,
      transparent,
      hsla(0, 0%, 100%, 0.06) 20%,
      hsla(0, 0%, 100%, 0.06) 80%,
      transparent
    );
  }

  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
  }

  .footer-copy {
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.25);
    margin: 0;
  }

  .footer-back-top {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.35);
    text-decoration: none;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 999px;
    padding: 6px 14px;
    transition:
      color 0.2s,
      border-color 0.2s;
  }

  .footer-back-top:hover {
    color: #9dc3f7;
    border-color: rgba(157, 195, 247, 0.3);
  }

  @media (max-width: 640px) {
    .footer-top {
      flex-direction: column;
      gap: 32px;
    }

    .footer-brand {
      max-width: 100%;
    }
  }
</style>

<script>
  const btn = document.getElementById("backToTop");
  btn?.addEventListener("click", (e) => {
    e.preventDefault();
    window.scrollTo({ top: 0, behavior: "smooth" });
  });
</script>
