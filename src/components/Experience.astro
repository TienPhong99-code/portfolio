---
const experiences = [
  {
    period: "2023 — Hiện tại",
    company: "Mona Media",
    title: "Frontend Developer",
    description:
      "Phát triển giao diện website cho các thương hiệu lớn tại Việt Nam. Cắt giao diện pixel-perfect từ Figma sang WordPress & React, tối ưu animation và trải nghiệm người dùng.",
    tags: ["WordPress", "React", "GSAP", "Tailwind CSS", "Figma"],
    current: true,
  },
  {
    period: "2022 — 2023",
    company: "Công ty ...",
    title: "Junior Frontend Developer",
    description:
      "Xây dựng và bảo trì giao diện website cho khách hàng. Phát triển WordPress theme từ đầu, làm việc với HTML, CSS, JavaScript và jQuery.",
    tags: ["HTML/CSS", "JavaScript", "WordPress", "jQuery"],
    current: false,
  },
  {
    period: "2021 — 2022",
    company: "...",
    title: "Frontend Intern",
    description:
      "Bắt đầu hành trình lập trình với vai trò thực tập sinh. Học và áp dụng HTML, CSS, JavaScript vào các dự án thực tế đầu tiên.",
    tags: ["HTML", "CSS", "JavaScript", "Git"],
    current: false,
  },
];
---

<section class="section sec-experience py-20">
  <div class="container">
    <div class="flex flex-col gap-16">
      <div class="flex flex-col gap-4 items-center text-center px-3">
        <div
          class="subheadline-box opacity flex items-center gap-2 px-4 py-2 bg-white/5 rounded-full border border-white/10"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="text-gray-400"
            ><rect width="20" height="14" x="2" y="7" rx="2"></rect><path
              d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path></svg
          >
          <span class="text-sm text-gray-400 uppercase tracking-widest"
            >Kinh nghiệm</span
          >
        </div>
        <h2 class="text-4xl md:text-5xl font-bold text-white">
          Hành Trình Sự Nghiệp
        </h2>
        <p class="text-gray-400 max-w-2xl">
          Mỗi vị trí là một chương mới, mỗi dự án là một bài học — hành trình
          tôi không ngừng học hỏi và phát triển.
        </p>
      </div>

      <div class="exp-timeline max-w-3xl mx-auto w-full">
        {
          experiences.map((exp, i) => (
            <div class="exp-item">
              <div class="exp-line-col">
                <div class={`exp-dot${exp.current ? " exp-dot--active" : ""}`}>
                  {exp.current && <span class="exp-dot-ring" />}
                </div>
                {i < experiences.length - 1 && (
                  <div class="exp-connector" />
                )}
              </div>

              <div class="exp-content">
                <span class="exp-period">{exp.period}</span>
                <div class="exp-card">
                  <div class="exp-card-header">
                    <div>
                      <h3 class="exp-title">{exp.title}</h3>
                      <p class="exp-company">{exp.company}</p>
                    </div>
                    {exp.current && (
                      <span class="exp-badge">Hiện tại</span>
                    )}
                  </div>
                  <p class="exp-desc">{exp.description}</p>
                  <div class="exp-tags">
                    {exp.tags.map((tag) => (
                      <span class="exp-tag">{tag}</span>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .exp-timeline {
    display: flex;
    flex-direction: column;
  }

  .exp-item {
    display: flex;
    gap: 24px;
    opacity: 0;
    transform: translateY(32px);
  }

  .exp-line-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
    padding-top: 6px;
  }

  .exp-dot {
    position: relative;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.2);
    border: 2px solid rgba(255, 255, 255, 0.2);
    flex-shrink: 0;
    z-index: 1;
  }

  .exp-dot--active {
    background: #9dc3f7;
    border-color: #9dc3f7;
  }

  .exp-dot-ring {
    position: absolute;
    inset: -5px;
    border-radius: 50%;
    border: 1.5px solid rgba(157, 195, 247, 0.35);
    animation: exp-pulse 2.4s ease-in-out infinite;
  }

  @keyframes exp-pulse {
    0%,
    100% {
      opacity: 1;
      transform: scale(1);
    }
    50% {
      opacity: 0.4;
      transform: scale(1.3);
    }
  }

  .exp-connector {
    width: 1px;
    flex: 1;
    min-height: 32px;
    background: linear-gradient(
      to bottom,
      rgba(255, 255, 255, 0.12),
      rgba(255, 255, 255, 0.04)
    );
    margin-top: 8px;
    margin-bottom: 8px;
  }

  .exp-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding-bottom: 40px;
  }

  .exp-period {
    font-size: 0.75rem;
    font-weight: 500;
    color: rgba(157, 195, 247, 0.7);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .exp-card {
    display: flex;
    flex-direction: column;
    gap: 14px;
    padding: 24px;
    border-radius: 16px;
    background: hsla(0, 0%, 100%, 0.03);
    box-shadow:
      inset 0 0 0 1px hsla(0, 0%, 100%, 0.08),
      inset 0 0 5vw hsla(0, 0%, 100%, 0.02);
    transition: background 0.3s ease;
  }

  .exp-card:hover {
    background: hsla(0, 0%, 100%, 0.05);
  }

  .exp-card-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
  }

  .exp-title {
    font-size: 1.05rem;
    font-weight: 600;
    color: #fff;
    margin: 0;
  }

  .exp-company {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.45);
    margin: 4px 0 0;
  }

  .exp-badge {
    flex-shrink: 0;
    font-size: 0.7rem;
    font-weight: 600;
    color: #9dc3f7;
    background: rgba(157, 195, 247, 0.1);
    border: 1px solid rgba(157, 195, 247, 0.25);
    border-radius: 999px;
    padding: 3px 10px;
    white-space: nowrap;
  }

  .exp-desc {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.55);
    line-height: 1.65;
    margin: 0;
  }

  .exp-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .exp-tag {
    font-size: 0.7rem;
    color: rgba(255, 255, 255, 0.5);
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 999px;
    padding: 3px 10px;
  }

  @media (max-width: 640px) {
    .exp-item {
      gap: 16px;
    }

    .exp-card {
      padding: 18px;
    }
  }
</style>
